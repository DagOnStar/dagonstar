[dagon_service]
route = http://localhost:57000
use = False

[ftp_pub]
ip = localhost

[dagon_ip]
ip = localhost

[batch]
scratch_dir_base=/tmp/
run_base=
remove_dir=False
threads=1

; Use DynoStore to store intermedary results in a reliabile storage system
; [dynostore]
; host=localhost
; port=80
; cypher=True
;reliability=True

[slurm]
partition=

; Define any number of OpenAI-compatible LLM providers as [llm.<name>].
; Keep real keys in an ignored local dagon.ini or environment variable.
; [llm.example]
; endpoint=https://api.example.com
; api_key_env=DAGON_LLM_EXAMPLE_API_KEY
; model=example-chat-model

[ec2]
key=<aws_access_key_id>
secret=<aws_secret_access_key>
region=

[digitalocean]
key=

[gce]
key=
secret=
project=

[loggers]
keys=root

[handlers]
keys=stream_handler

[formatters]
keys=formatter

[logger_root]
level=DEBUG
handlers=stream_handler

[handler_stream_handler]
class=StreamHandler
level=DEBUG
formatter=formatter
args=(sys.stderr,)

[formatter_formatter]
format=%(asctime)s %(name)-12s %(levelname)-8s %(message)s
